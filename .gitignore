__pycache__/
*.pyc
.pytest_cache/
.venv/

# Claude Code session files
.claude/settings.local.json

# Build trees (per-component Makefiles drop intermediates here).
ground/build/
vehicle/build/
probes/build/
wfb-ng/build/
wfb-ng/install/

# xxd-generated WebUI asset headers (regenerate via the per-component
# `make webui` target).
ground/webui/gs_assets.h
vehicle/webui/index_assets.h

# Developer-machine convenience symlinks that some local workflows expect at
# the repo root (not part of the canonical tree).  Typically point at the
# sibling waybeam_venc/ checkout.
/include
/src
/toolchain
/tools

# Telemetry / link-ML: generated & reproducible artifacts (rebuild with
# gen_sample.py / train_tier1.py). The data-session DB telemetry/wfb.sqlite IS
# committed (small + portable; a tagged demo session); only its transient
# WAL/SHM/journal sidecars are ignored so we never commit a half-flushed DB.
telemetry/sample_wfb.jsonl
telemetry/*_wfb.jsonl
telemetry/model/
telemetry/model_*/
telemetry/loop/
telemetry/*.sqlite-journal
telemetry/*.sqlite-wal
telemetry/*.sqlite-shm
